<Project>
  <PropertyGroup>
    <VersionPrefix>1.0.0</VersionPrefix>
    
    <ActualBuildNumber Condition="'$(BUILD_NUMBER)' == ''">0</ActualBuildNumber>
    <ActualBuildNumber Condition="'$(BUILD_NUMBER)' != ''">$(BUILD_NUMBER)</ActualBuildNumber>

    <Version>$(VersionPrefix).$(ActualBuildNumber)</Version>
    <AssemblyVersion>$(VersionPrefix).0</AssemblyVersion>
    <FileVersion>$(VersionPrefix).$(ActualBuildNumber)</FileVersion>
    
    <InformationalVersion>$(VersionPrefix) (Build: $(ActualBuildNumber))</InformationalVersion>
  </PropertyGroup>
</Project>