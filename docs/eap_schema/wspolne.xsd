	<xs:attributeGroup name="referencja">
		<xs:annotation>
			<xs:documentation>Atrybuty opisujące odwołanie do zewnętrznego pliku binarnego dla grafiki.</xs:documentation>
		</xs:annotation>
		<xs:attribute name="href" type="xs:anyURI" use="required"/>
    <xs:attribute name="skrot" type="xs:string" />
	</xs:attributeGroup>
	
	<xs:element name="grafika">
		<xs:annotation>
			<xs:documentation>Odwołanie do zewnętrznego pliku zawierającego grafikę rastrową.</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:complexContent>
				<xs:extension base="JednostkaRedakcyjnaTyp">
					<xs:attributeGroup ref="referencja"/>
          <xs:attribute name="width" type="xs:string">
            <xs:annotation>
              <xs:documentation>Szerokość do jakiej ma być przeskalowany obrazek.</xs:documentation>
            </xs:annotation>
          </xs:attribute>
          <xs:attribute name="height" type="xs:string">
            <xs:annotation>
              <xs:documentation>Wysokość do jakiej ma być przeskalowany obrazek.</xs:documentation>
            </xs:annotation>
          </xs:attribute>
					<xs:attribute name="alt" type="xs:string">
						<xs:annotation>
							<xs:documentation>Tekstowy opis grafiki.</xs:documentation>
						</xs:annotation>
					</xs:attribute>
				</xs:extension>
			</xs:complexContent>
		</xs:complexType>
	</xs:element>
	<xs:element name="grafika-wektorowa">
		<xs:annotation>
			<xs:documentation>Grafika wektorowa zapisana w formacie SVG.</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:complexContent>
				<xs:extension base="JednostkaRedakcyjnaTyp">
					<xs:sequence>
						<xs:any namespace="http://www.w3.org/2000/svg" processContents="skip"/>
					</xs:sequence>
					<xs:attribute name="href" type="xs:anyURI">
						<xs:annotation>
						  <xs:documentation>Opcjonalna referencja do grafiki rastrowej reprezentującej rysunek.</xs:documentation>
						</xs:annotation>
					</xs:attribute>
          <xs:attribute name="width" type="xs:string">
            <xs:annotation>
              <xs:documentation>Szerokość do jakiej ma być przeskalowany rysunek.</xs:documentation>
            </xs:annotation>
          </xs:attribute>
          <xs:attribute name="height" type="xs:string">
            <xs:annotation>
              <xs:documentation>Wysokość do jakiej ma być przeskalowany rysunek.</xs:documentation>
            </xs:annotation>
          </xs:attribute>
					<xs:attribute name="skrot" type="xs:string">
						<xs:annotation>
						  <xs:documentation>Skrót opcjonalnej grafiki rastrowej reprezentującej rysunek.</xs:documentation>
						</xs:annotation>
					</xs:attribute>
				</xs:extension>
			</xs:complexContent>
		</xs:complexType>
	</xs:element>
	<xs:element name="wzor-mat">
		<xs:annotation>
			<xs:documentation>Wzór matematyczny zapisany w języku MathML wraz z objaśnieniami symboli.</xs:documentation>
		</xs:annotation>
		<xs:complexType>
			<xs:complexContent>
				<xs:extension base="JednostkaRedakcyjnaTyp">
					<xs:sequence>
						<xs:element ref="mml:math"/>
						<xs:element name="opis" minOccurs="0" maxOccurs="unbounded">
							<xs:annotation>
								<xs:documentation>Opis pojedynczego symbolu użytego we wzorze.</xs:documentation>
							</xs:annotation>
							<xs:complexType>
								<xs:sequence>
									<xs:choice minOccurs="0">
										<xs:element name="symbol-txt" type="ZawartoscTekstowaBezCytatuTyp">
											<xs:annotation>
												<xs:documentation>Opisywany symbol przedstawiony w formie tekstowej.</xs:documentation>
											</xs:annotation>
										</xs:element>
										<xs:element name="symbol-mat">
											<xs:annotation>
												<xs:documentation>Opisywany symbol przedstawiony jako wyrażenie w języku MathML.</xs:documentation>
											</xs:annotation>
											<xs:complexType>
												<xs:sequence>
													<xs:element ref="mml:math"/>
												</xs:sequence>
												<xs:attribute name="grafika" type="xs:anyURI">
													<xs:annotation>
														<xs:documentation>Opcjonalna referencja do grafiki reprezentującej symbol matematyczny.</xs:documentation>
													</xs:annotation>
												</xs:attribute>
												<xs:attribute name="skrot" type="xs:string">
												  <xs:annotation>
													<xs:documentation>Skrót opcjonalnej grafiki reprezentującej symbol matematyczny.</xs:documentation>
												  </xs:annotation>
												</xs:attribute>
											</xs:complexType>
										</xs:element>
									</xs:choice>
									<xs:element name="objasnienie">
										<xs:annotation>
											<xs:documentation>Objaśnienie znaczenia symbolu.</xs:documentation>
										</xs:annotation>
										<xs:complexType>
											<xs:group ref="tresc-akapitowa"/>
										</xs:complexType>
									</xs:element>
								</xs:sequence>
							</xs:complexType>
						</xs:element>
					</xs:sequence>
					<xs:attribute name="grafika" type="xs:anyURI">
						<xs:annotation>
							<xs:documentation>Opcjonalna referencja do grafiki reprezentującej wzór matematyczny.</xs:documentation>
						</xs:annotation>
					</xs:attribute>
          <xs:attribute name="skrot" type="xs:string">
            <xs:annotation>
              <xs:documentation>Skrót opcjonalnej grafiki reprezentującej symbol matematyczny.</xs:documentation>
            </xs:annotation>
          </xs:attribute>
				</xs:extension>
			</xs:complexContent>
		</xs:complexType>
	</xs:element>

